<?xml version="1.0" encoding="utf-8"?>
<!-- 悬浮窗：紧凑竖排，半透明黑底 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="80dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/bg_float_panel"
    android:padding="8dp">

    <!-- 当前模式标签 -->
    <TextView
        android:id="@+id/tv_float_mode"
        android:layout_width="64dp"
        android:layout_height="26dp"
        android:text="评论"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/bg_mode_comment"
        android:layout_marginBottom="6dp" />

    <!-- 替换按钮（主操作） -->
    <TextView
        android:id="@+id/btn_float_replace"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:text="替换"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/bg_replace_circle"
        android:layout_marginBottom="6dp" />

    <!-- 底部两个小按钮 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/btn_float_switch"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:text="切"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:gravity="center"
            android:background="@drawable/bg_small_circle_gray"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/btn_float_close"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:text="✕"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:gravity="center"
            android:background="@drawable/bg_small_circle_gray" />
    </LinearLayout>

</LinearLayout>
