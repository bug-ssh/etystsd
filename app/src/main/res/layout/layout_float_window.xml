<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:clipToPadding="false"
    android:clipChildren="false"
    android:padding="0dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/transparent"
        android:padding="0dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tv_float_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="评论"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:background="@android:color/transparent"
            android:padding="6dp"
            android:gravity="center" />

        <TextView
            android:id="@+id/btn_float_replace"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_replace_circle"
            android:gravity="center"
            android:text="替换"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_float_switch"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_small_circle_gray"
            android:gravity="center"
            android:text="切"
            android:textColor="#FFFFFFFF"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/btn_float_close"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_small_circle_gray"
            android:gravity="center"
            android:text="✕"
            android:textColor="#FFFFFFFF"
            android:textSize="12sp" />
    </LinearLayout>
</FrameLayout>
