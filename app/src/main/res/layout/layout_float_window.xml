<?xml version="1.0" encoding="utf-8"?>
<!-- Float window: compact vertical layout, semi-transparent -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="84dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/bg_float_panel"
    android:padding="10dp"
    android:elevation="8dp">

    <!-- Current mode label -->
    <TextView
        android:id="@+id/tv_float_mode"
        android:layout_width="68dp"
        android:layout_height="28dp"
        android:text="Comment"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/bg_mode_comment"
        android:layout_marginBottom="8dp" />

    <!-- Replace button (main action) -->
    <TextView
        android:id="@+id/btn_float_replace"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:text="Replace"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/bg_replace_circle"
        android:layout_marginBottom="8dp" />

    <!-- Bottom buttons row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/btn_float_switch"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="Mode"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:gravity="center"
            android:background="@drawable/bg_small_circle_gray"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/btn_float_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="X"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:background="@drawable/bg_small_circle_gray" />
    </LinearLayout>

</LinearLayout>
