<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scroll_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0F"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:paddingBottom="40dp">

        <!-- ══ Top Title ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="52dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voice Assistant"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Douyin Custom Edition"
                android:textColor="#8E8E93"
                android:textSize="14sp"
                android:layout_marginTop="5dp" />
        </LinearLayout>

        <!-- ══ Root Status Badge ══ -->
        <LinearLayout
            android:id="@+id/root_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_badge_gray"
            android:paddingLeft="18dp"
            android:paddingRight="18dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tv_root_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Root: detecting..."
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ══ Replacement Audio Card ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Replacement Audio"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_pick_audio"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Select Audio File"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:background="@drawable/bg_btn_blue"
                android:stateListAnimator="@null" />

            <TextView
                android:id="@+id/tv_audio_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#4CAF50"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:layout_marginTop="10dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- ══ Target Path Settings Card ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Target Path Settings"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="14dp" />

            <!-- Comment path -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Comment Voice Directory"
                android:textColor="#8E8E93"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_comment_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_path_field"
                android:padding="12dp"
                android:textColor="#E5E5EA"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:singleLine="false"
                android:inputType="textMultiLine|textNoSuggestions"
                android:layout_marginBottom="16dp"
                android:hint="/data/data/.../files/comment/audio"
                android:textColorHint="#636366" />

            <!-- IM path -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IM Voice Directory"
                android:textColor="#8E8E93"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_im_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_path_field"
                android:padding="12dp"
                android:textColor="#E5E5EA"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:singleLine="false"
                android:inputType="textMultiLine|textNoSuggestions"
                android:hint="/data/data/.../files/im"
                android:textColorHint="#636366" />
        </LinearLayout>

        <!-- ══ File Browser Card ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Target File (Optional)"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Browse to select specific voice file to overwrite"
                android:textColor="#8E8E93"
                android:textSize="11sp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_browse_file"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Browse Root Files"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="@drawable/bg_btn_blue"
                android:stateListAnimator="@null" />

            <TextView
                android:id="@+id/tv_target_file"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FF9800"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginTop="10dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- ══ Save & Start ══ -->
        <Button
            android:id="@+id/btn_save_start"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save &amp; Start Float Window"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_red"
            android:stateListAnimator="@null"
            android:layout_marginBottom="16dp" />

        <!-- ══ Appearance Settings Card ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Appearance"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="14dp" />

            <!-- Background -->
            <Button
                android:id="@+id/btn_set_bg"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Set Background Image"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="@drawable/bg_btn_blue"
                android:stateListAnimator="@null"
                android:layout_marginBottom="14dp" />

            <!-- Font size -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Font Size"
                android:textColor="#8E8E93"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btn_font_small"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="S"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:background="#3A3A3C"
                    android:stateListAnimator="@null"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/btn_font_medium"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="M"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:background="#FF3B5C"
                    android:stateListAnimator="@null"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/btn_font_large"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="40dp"
                    android:text="L"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:background="#3A3A3C"
                    android:stateListAnimator="@null" />
            </LinearLayout>
        </LinearLayout>

        <!-- ══ Usage Tips ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usage Tips"
                android:textColor="#FF3B5C"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Select replacement audio file\n2. Set target directories (defaults pre-filled)\n3. (Optional) Browse to pick specific target file\n4. Tap Save &amp; Start Float Window\n5. Go to Douyin, record 1-30s voice, DON'T send\n6. Tap float window to switch mode, tap Replace\n7. Long-press Replace to change audio on the fly\n8. Long-press Close to collapse/expand float"
                android:textColor="#EBEBF5"
                android:textSize="13sp"
                android:lineSpacingExtra="5dp"
                android:layout_gravity="center_horizontal"
                android:gravity="start" />
        </LinearLayout>

        <!-- ══ Footer ══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Requires Root permission"
            android:textColor="#48484A"
            android:textSize="11sp"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
