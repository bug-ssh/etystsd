<?xml version="1.0" encoding="utf-8"?>
<!--
  严格还原截图：
  - 背景 #1C1C1E（深灰黑）
  - 顶部大标题"语音助手" + 副标题"抖音定制版"
  - 白色圆角卡片（内含两个路径只读框）
  - 红色大按钮"保存并启动悬浮窗"
  - 淡色提示卡片（💡 操作提示）
  - 底部小字"请确保已授予 Root 及悬浮窗权限"
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1C1C1E"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingBottom="40dp">

        <!-- ── 顶部标题区 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="60dp"
            android:paddingBottom="36dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="语音助手"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="抖音定制版"
                android:textColor="#8E8E93"
                android:textSize="15sp"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- ── 路径卡片 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <!-- 评论语音目录 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="评论语音目录"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tv_comment_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="/data/data/com.ss.android.ugc.aweme/files/comment/audio"
                android:textColor="#EBEBF5"
                android:textSize="13sp"
                android:background="@drawable/bg_path_field"
                android:padding="14dp"
                android:fontFamily="monospace"
                android:layout_marginBottom="20dp" />

            <!-- 私聊语音目录 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="私聊语音目录"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/tv_im_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="/data/data/com.ss.android.ugc.aweme/files/im"
                android:textColor="#EBEBF5"
                android:textSize="13sp"
                android:background="@drawable/bg_path_field"
                android:padding="14dp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- ── 保存并启动悬浮窗 ── -->
        <Button
            android:id="@+id/btn_save_start"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="保存并启动悬浮窗"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_red"
            android:stateListAnimator="@null"
            android:layout_marginBottom="20dp" />

        <!-- ── 操作提示卡片 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:layout_marginBottom="32dp">

            <!-- 标题行 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡"
                    android:textSize="18sp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="操作提示"
                    android:textColor="#FF3B5C"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 提示内容 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="在评论区或私聊录制1-30秒语音后不要发送\n点击悬浮窗切换对应模式并点击替换"
                android:textColor="#EBEBF5"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- ── 底部提示 ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="请确保已授予 Root 及悬浮窗权限"
            android:textColor="#48484A"
            android:textSize="12sp"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
